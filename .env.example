SECRET_KEY=your-50-char-secret-key-here

# False in production, True in development
DEBUG=False

# Comma-separated. Add your Render URL here.
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.onrender.com

# PostgreSQL — Supabase values in production
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432

# Redis — Railway URL in production
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
CORS_ALLOW_ALL_ORIGINS=False

# SMS
SMS_API_KEY=dev-fake-key
SMS_SENDER_ID=Nirapod
