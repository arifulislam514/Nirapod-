SECRET_KEY=your-50-char-secret-key-here
DEBUG=False

# Comma-separated — add your Render URL
ALLOWED_HOSTS=localhost,127.0.0.1,nirapod-backend.onrender.com

# PostgreSQL (Supabase in production)
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432

# Redis (Render Redis internal URL)
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
CORS_ALLOW_ALL_ORIGINS=False

# CSRF (add your Render URL)
CSRF_TRUSTED_ORIGINS=https://nirapod-backend.onrender.com,http://localhost:8000
